APP_NAME="Nuno Backend"
ENVIRONMENT="development"
API_V1_PREFIX="/api/v1"
DEBUG=true
CORS_ORIGINS=["http://localhost:3000"]
CORS_ORIGIN_REGEX="^https?://(localhost|127\\.0\\.0\\.1)(:\\d+)?$"

MONGODB_URI="mongodb://mongo:27017"
MONGODB_DB_NAME="nuno"

JWT_SECRET_KEY="replace-with-a-strong-secret"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=20160
RESET_TOKEN_EXPIRE_MINUTES=15

OTP_EXPIRE_MINUTES=10
OTP_LENGTH=6

CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_FOLDER="nunu-service-provider"

PLATFORM_ADMIN_EMAIL="admin@example.com"
PLATFORM_ADMIN_PASSWORD="replace-with-a-strong-admin-password"
PLATFORM_ADMIN_FULL_NAME="Platform Admin"


LOYALTY_POINTS_ON_CONFIRM=50

OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"

